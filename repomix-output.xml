                    className="pl-10 bg-white/5 border-white/10 text-zinc-100 placeholder:text-zinc-500 focus:border-cyan-500/50"
                    required
                  />
                </div>
              </div>
              {error && (
                <p className="text-sm text-red-400 text-center">{error}</p>
              )}
